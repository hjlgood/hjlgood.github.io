---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "The Value Matrix", 
  description = "Independent thoughts on software engineering, technology design, and quantitative finance." 
} = Astro.props;

// Format current date in newspaper style (e.g., "Monday, July 6, 2026")
const todayFormatted = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/favicon-matrix.jpg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    
    <!-- Google Fonts for Newspaper Theme -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,700&family=Lora:ital,wght@0,400;0,500;0,700;1,400&family=Inter:wght@400;500;600;700&family=Fira+Code&display=swap" rel="stylesheet" />
    
    <!-- Script to prevent FOUC by setting theme early -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }
    </script>
  </head>
  <body>
    <div class="newspaper-wrapper">
      <header class="masthead container">
        <!-- Top Utility Row -->
        <div class="masthead-top">
          <span>"All the Code That's Fit to Print"</span>
          <span>ESTABLISHED 2026</span>
        </div>

        <!-- Huge Centered Masthead Title -->
        <div class="masthead-main">
          <a href="/">The Value Matrix</a>
        </div>

        <!-- Double Border Metadata Bar -->
        <div class="masthead-meta double-border-top double-border-bottom">
          <div class="meta-item volume">VOL. I ... NO. 42</div>
          <div class="meta-item date">{todayFormatted}</div>
          <div class="meta-item weather">SEOUL • CLOUDY • 26°C</div>
        </div>

        <!-- Navigation Bar -->
        <nav class="masthead-nav single-border-bottom">
          <a href="/" class="nav-link">FRONT PAGE</a>
          <span class="nav-sep">|</span>
          <a href="#articles" class="nav-link">OPINION & WRITING</a>
          <span class="nav-sep">|</span>
          <a href="#about" class="nav-link">EDITORIAL BOARD</a>
          <span class="nav-sep">|</span>
          <button id="theme-toggle" class="nav-link theme-toggle-nav-btn" aria-label="Toggle Edition">
            <span class="light-text">DARK EDITION</span>
            <span class="dark-text">LIGHT EDITION</span>
          </button>
        </nav>
      </header>

      <main class="main-content">
        <slot />
      </main>

      <footer class="footer">
        <div class="container footer-container double-border-top">
          <div class="footer-masthead">The Value Matrix</div>
          <div class="footer-sections">
            <div class="footer-col">
              <h4>SECTIONS</h4>
              <a href="/">Front Page</a>
              <a href="#articles">Opinion & Writing</a>
              <a href="#about">Editorial Board</a>
            </div>
            <div class="footer-col">
              <h4>CORRESPONDENTS</h4>
              <a href="https://github.com/hjlgood" target="_blank" rel="noopener noreferrer">GitHub</a>
              <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
              <a href="https://twitter.com" target="_blank" rel="noopener noreferrer">Twitter</a>
            </div>
            <div class="footer-col subscription-col">
              <h4>SUBSCRIPTIONS</h4>
              <p>Sign up to receive our weekly dispatch on software architectures, design philosophy, and finance.</p>
              <a href="mailto:contact@hjlgood.io" class="subscribe-btn">WRITE AN EDITORIAL</a>
            </div>
          </div>
          <div class="footer-bottom single-border-top">
            <p>&copy; {new Date().getFullYear()} The Value Matrix. Published daily. All rights reserved.</p>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>

<style>
  .newspaper-wrapper {
    max-width: 1280px;
    margin: 0 auto;
    padding: 24px 0;
  }

  /* Masthead Styles */
  .masthead {
    text-align: center;
    margin-bottom: 24px;
  }

  .masthead-top {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    padding-bottom: 8px;
    text-transform: uppercase;
  }

  .masthead-main {
    padding: 16px 0;
  }

  .masthead-main a {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 7vw, 4.8rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    line-height: 0.95;
    display: inline-block;
  }

  .masthead-meta {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    align-items: center;
    padding: 8px 0;
    margin-bottom: 12px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .volume {
    text-align: left;
  }

  .date {
    text-align: center;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .weather {
    text-align: right;
  }

  .masthead-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    padding-bottom: 12px;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  .nav-link {
    color: var(--text-primary);
    padding: 4px 8px;
  }

  .nav-link:hover {
    color: var(--accent-color);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .nav-sep {
    color: var(--border-light);
    font-weight: 300;
  }

  /* Main Content Area */
  .main-content {
    margin-top: 16px;
  }

  /* Footer Styles */
  .footer {
    margin-top: 64px;
    padding-top: 32px;
  }

  .footer-masthead {
    font-family: var(--font-serif);
    font-size: 2.25rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    text-align: center;
    margin-bottom: 32px;
    padding-top: 24px;
  }

  .footer-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 40px;
    padding-bottom: 40px;
  }

  .footer-col h4 {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 8px;
    margin-bottom: 16px;
  }

  .footer-col a {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 10px;
  }

  .footer-col a:hover {
    color: var(--accent-color);
    text-decoration: underline;
  }

  .subscription-col p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .subscribe-btn {
    display: inline-block;
    border: 1px solid var(--border-color);
    padding: 8px 16px;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    background-color: var(--text-primary);
    color: var(--bg-primary) !important;
    text-transform: uppercase;
    transition: var(--transition-fast);
  }

  .subscribe-btn:hover {
    background-color: var(--accent-color);
    border-color: var(--accent-color);
    color: var(--bg-primary) !important;
    text-decoration: none !important;
  }

  .footer-bottom {
    padding: 24px 0;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: center;
  }

  @media (max-width: 768px) {
    .masthead-meta {
      grid-template-columns: 1fr;
      gap: 8px;
      text-align: center;
    }
    .volume, .weather {
      text-align: center;
    }
    .nav-sep {
      display: none;
    }
    .masthead-nav {
      flex-direction: column;
      gap: 8px;
    }
  }

  /* Theme Toggle Button Styles (Styled like a navigation link) */
  .theme-toggle-nav-btn {
    background: none;
    border: none;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    cursor: pointer;
    line-height: inherit;
    display: inline-block;
  }

  .dark-text {
    display: none;
  }

  :global([data-theme="dark"]) .light-text {
    display: none;
  }

  :global([data-theme="dark"]) .dark-text {
    display: inline;
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const currentTheme = document.documentElement.getAttribute('data-theme');
      if (currentTheme === 'dark') {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  }
</script>
