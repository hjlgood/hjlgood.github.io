---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
const { title, description, pubDate, heroImage } = frontmatter;
---

<Layout title={`${title} | The Hidden Tickers`} description={description}>
  <article class="blog-post-container container fade-in">
    <header class="post-header">
      <div class="post-kicker">EDITORIAL OPINION</div>
      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>
      
      <!-- Editorial Byline / Dateline bar -->
      <div class="post-byline-bar single-border-top single-border-bottom">
        <div class="byline-left">
          <span>By <strong>JL Hwang</strong></span>
          <span class="byline-separator">•</span>
          <span>Special to The Hidden Tickers</span>
        </div>
        <div class="byline-right">
          <time datetime={pubDate}>
            {new Date(pubDate).toLocaleDateString('en-US', {
              weekday: 'long',
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
        </div>
      </div>

      {heroImage && (
        <div class="post-hero-image-wrapper">
          <div class="newspaper-image-placeholder">
            <div class="raster-dots"></div>
            <span>[ ARCHIVAL ILLUSTRATION ]</span>
          </div>
          <span class="image-caption">Analyzing the macroeconomic indicators governing memory-semiconductors and quantitative strategies.</span>
        </div>
      )}
    </header>
    
    <div class="post-body dropcap-post">
      <slot />
    </div>
  </article>
</Layout>

<style is:global>
  /* Blog post newspaper styling */
  .blog-post-container {
    max-width: 760px;
    padding-top: 40px;
    padding-bottom: 96px;
  }

  .post-header {
    margin-bottom: 32px;
    text-align: center;
  }

  .post-kicker {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--accent-color);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .post-description {
    font-family: var(--font-body);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 640px;
    margin: 0 auto 24px auto;
  }

  .post-byline-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    margin: 24px 0;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .byline-separator {
    margin: 0 8px;
    color: var(--border-light);
  }

  .post-hero-image-wrapper {
    margin-top: 24px;
    text-align: left;
  }

  .post-hero-image-wrapper .newspaper-image-placeholder {
    height: 360px;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    position: relative;
    overflow: hidden;
  }

  .post-hero-image-wrapper .raster-dots {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle, rgba(18,18,18,0.15) 1px, transparent 1px);
    background-size: 6px 6px;
    opacity: 0.5;
  }

  .image-caption {
    display: block;
    font-size: 0.75rem;
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.4;
    margin-top: 8px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-light);
  }

  /* Article Body Formatting (Broadsheet Print Style) */
  .post-body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
    text-align: justify;
  }

  /* Dropcap for the very first paragraph in the post */
  .dropcap-post > p:first-of-type::first-letter {
    font-family: var(--font-serif);
    float: left;
    font-size: 4.8rem;
    line-height: 0.8;
    padding-top: 4px;
    padding-right: 8px;
    font-weight: 900;
    color: var(--text-primary);
  }

  .post-body h2 {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-top: 40px;
    margin-bottom: 12px;
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 4px;
  }

  .post-body h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 28px;
    margin-bottom: 8px;
  }

  .post-body p {
    margin-bottom: 20px;
    text-indent: 0px; /* Optional, but default layout has spaces */
  }

  .post-body ul, .post-body ol {
    margin-bottom: 20px;
    padding-left: 24px;
  }

  .post-body li {
    margin-bottom: 8px;
  }

  .post-body blockquote {
    border-left: 3px solid var(--accent-color);
    padding-left: 16px;
    margin: 24px 0;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--text-primary);
  }

  .post-body strong {
    color: var(--text-primary);
  }

  .post-body code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background-color: var(--bg-secondary);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-light);
    color: var(--text-primary);
  }

  @media (max-width: 576px) {
    .post-byline-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
