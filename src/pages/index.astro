---
import Layout from '../layouts/Layout.astro';
import { Content as EditorDeskContent, frontmatter as editorFrontmatter } from '../content/editor-desk.md';
import { Content as BoardMissionContent, frontmatter as boardFrontmatter } from '../content/board-mission.md';

interface BoardMember {
  name: string;
  role: string;
}

interface PostFrontmatter {
  title: string;
  description: string;
  pubDate: string;
  [key: string]: any;
}

interface PostModule {
  url: string;
  frontmatter: PostFrontmatter;
}

// Fetch all markdown files in src/pages/blog/ dynamically using Vite glob imports
const postFiles = import.meta.glob<PostModule>('./blog/*.md', { eager: true });
const allPosts: PostModule[] = Object.values(postFiles);

// Sort posts by pubDate (newest first)
const sortedPosts = allPosts.sort((a: PostModule, b: PostModule) => {
  const dateA = new Date(a.frontmatter.pubDate || '1970-01-01').getTime();
  const dateB = new Date(b.frontmatter.pubDate || '1970-01-01').getTime();
  return dateB - dateA;
});

// Select the newest post as the main headline lead
const leadPost = sortedPosts.length > 0 ? sortedPosts[0] : null;

// The rest of the posts go to the Opinion column
const opinionPosts = sortedPosts.length > 1 ? sortedPosts.slice(1) : [];
---

<Layout>
  <!-- Wrap in a container to align perfectly with the header masthead -->
  <div class="broadsheet container fade-in">
    <div class="broadsheet-grid double-border-bottom">
      
      <!-- COLUMN 1 (LEFT): Editor's Desk / Personal Biography -->
      <aside class="col col-left">
        <h3 class="col-header">EDITOR'S DESK</h3>
        
        <div class="editor-profile">
          <span class="columnist-tag">{editorFrontmatter.tag}</span>
          <h4><a href="#about">{editorFrontmatter.title}</a></h4>
          <div class="editor-text">
            <EditorDeskContent />
          </div>
          <div class="bulletin-detail">
            <span class="tech-spec">{editorFrontmatter.profileTag}</span>
            <p class="impact-text">{editorFrontmatter.profileText}</p>
          </div>
        </div>

        <hr class="bulletin-divider" />

        <div class="quick-links">
          <h4 class="mini-header">INDEX OF INSIDERS</h4>
          <ul class="index-list">
            <li><a href="/">Front Page</a></li>
            <li><a href="#articles">Opinion & Writing ({allPosts.length} posts)</a></li>
            <li><a href="#about">About the Editor</a></li>
          </ul>
        </div>
      </aside>

      <!-- COLUMN 2 (CENTER): The Lead Story (Dynamic from src/pages/blog/) -->
      <section class="col col-center">
        {leadPost ? (
          <div>
            <div class="lead-header">
              <span class="kicker">LATEST EDITION HEADLINE</span>
              <h2>
                <a href={leadPost.url}>{leadPost.frontmatter.title}</a>
              </h2>
              <p class="byline">
                By JL Hwang • Published on {new Date(leadPost.frontmatter.pubDate).toLocaleDateString('en-US', {
                  month: 'long',
                  day: 'numeric',
                  year: 'numeric'
                })}
              </p>
            </div>
            
            <div class="lead-image-wrapper">
              <div class="newspaper-image-placeholder">
                <div class="raster-dots"></div>
                <span>[ ILLUSTRATION: {leadPost.frontmatter.title.substring(0, 20).toUpperCase()}... ]</span>
              </div>
              <span class="caption">{leadPost.frontmatter.description}</span>
            </div>

            <p class="lead-text dropcap">
              {leadPost.frontmatter.description}
            </p>
            
            <div class="read-more-link">
              <a href={leadPost.url}>Read the full article →</a>
            </div>
          </div>
        ) : (
          <div class="no-posts-alert">
            <div class="lead-header">
              <span class="kicker">NOTICE TO READERS</span>
              <h2>No articles published yet</h2>
            </div>
            <p class="lead-text">
              To publish your first article, create a Markdown file (e.g., <code>first.md</code>) inside the <code>src/pages/blog/</code> directory with frontmatter metadata.
            </p>
            <p class="lead-text">
              Once created, Astro will automatically compile your Markdown file and feature it here on the front page.
            </p>
          </div>
        )}
      </section>

      <!-- COLUMN 3 (RIGHT): Opinion, Columnists & Other Articles (Dynamic from src/pages/blog/) -->
      <aside class="col col-right" id="articles">
        <h3 class="col-header">OPINIONS & LETTERS</h3>
        
        {opinionPosts.length > 0 ? (
          opinionPosts.map((post: PostModule, idx: number) => (
            <div class="opinion-item">
              <span class="opinion-category">ARTICLE № {idx + 1}</span>
              <h4><a href={post.url}>{post.frontmatter.title}</a></h4>
              <p>{post.frontmatter.description}</p>
              <div class="opinion-meta">
                <span>By JL Hwang</span>
                <span class="meta-dot"></span>
                <span>{new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
              </div>
              {idx < opinionPosts.length - 1 && <hr class="opinion-divider" />}
            </div>
          ))
        ) : (
          <div class="no-other-posts">
            <p class="empty-opinion-text">
              Additional articles will appear in this column as you add more Markdown files to the blog directory.
            </p>
            <div class="opinion-suggestion">
              <span class="suggestion-tag">TIP</span>
              <p>Create a second Markdown file in <code>src/pages/blog/</code> to fill this section.</p>
            </div>
          </div>
        )}
      </aside>

    </div>

    <!-- Editorial Board Info -->
    <section id="about" class="editorial-board">
      <div class="board-header">
        <h3>{boardFrontmatter.title}</h3>
      </div>
      <div class="board-content">
        <div class="board-statement">
          <BoardMissionContent />
        </div>
        <div class="board-members">
          {boardFrontmatter.members && boardFrontmatter.members.map((member: BoardMember) => (
            <div class="member">
              <h5>{member.name}</h5>
              <p>{member.role}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* Broadsheet layout wrapper */
  .broadsheet {
    margin-top: 24px;
    margin-bottom: 48px;
  }

  /* Grid Layout: 3 Columns matching broadsheet style */
  .broadsheet-grid {
    display: grid;
    grid-template-columns: 1fr 2fr 1.2fr;
    gap: 24px;
    padding-bottom: 24px;
  }

  /* Columns & Borders */
  .col {
    display: flex;
    flex-direction: column;
  }

  .col-left {
    border-right: 1px solid var(--border-light);
    padding-right: 16px;
  }

  .col-center {
    border-right: 1px solid var(--border-light);
    padding-left: 8px;
    padding-right: 16px;
  }

  .col-right {
    padding-left: 8px;
  }

  /* Column Headers */
  .col-header {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text-primary);
    border-bottom: 2px solid var(--border-color);
    padding-bottom: 4px;
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  /* Left Column (Editor Profile) */
  .columnist-tag {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--accent-color);
    letter-spacing: 0.05em;
  }

  .editor-profile h4 {
    font-size: 1.15rem;
    line-height: 1.25;
    margin: 4px 0 8px 0;
  }

  .editor-text p {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 12px;
    text-align: justify;
    word-break: keep-all;
  }

  .bulletin-detail {
    margin-top: 12px;
    background-color: var(--bg-secondary);
    padding: 10px;
    border-left: 2px solid var(--border-color);
  }

  .tech-spec {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--accent-blue);
    display: block;
    margin-bottom: 2px;
    letter-spacing: 0.05em;
  }

  .impact-text {
    font-family: var(--font-sans);
    font-size: 0.75rem !important;
    line-height: 1.4;
  }

  .bulletin-divider {
    border: none;
    border-top: 1px dotted var(--border-light);
    margin: 20px 0;
  }

  /* Quick links inside column 1 */
  .mini-header {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
    color: var(--text-primary);
  }

  .index-list {
    list-style: none;
    padding-left: 0;
  }

  .index-list li {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .index-list a {
    color: var(--text-secondary);
  }

  .index-list a:hover {
    color: var(--accent-color);
    text-decoration: underline;
  }

  /* Center Column (Lead Story) */
  .lead-header {
    text-align: center;
    margin-bottom: 16px;
  }

  .kicker {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--accent-color);
    text-transform: uppercase;
  }

  .lead-header h2 {
    font-size: clamp(1.6rem, 3.2vw, 2.25rem);
    line-height: 1.15;
    margin: 6px 0 8px 0;
    letter-spacing: -0.02em;
    word-break: keep-all;
  }

  .byline {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .lead-image-wrapper {
    margin-bottom: 16px;
  }

  .newspaper-image-placeholder {
    height: 240px;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    position: relative;
    overflow: hidden;
    padding: 0 16px;
    text-align: center;
  }

  .raster-dots {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle, rgba(18,18,18,0.12) 1px, transparent 1px);
    background-size: 5px 5px;
  }

  .caption {
    display: block;
    font-size: 0.75rem;
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.4;
    margin-top: 6px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-light);
  }

  .lead-text {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.65;
    margin-bottom: 16px;
    text-align: justify;
    word-break: keep-all;
  }

  .read-more-link {
    margin-top: 20px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .read-more-link a {
    color: var(--accent-color);
    text-decoration: underline;
  }

  /* Empty alert */
  .no-posts-alert {
    padding: 24px;
    border: 2px dashed var(--border-light);
    background-color: var(--bg-secondary);
    text-align: center;
  }

  /* Right Column (Opinions) */
  .opinion-item {
    margin-bottom: 20px;
  }

  .opinion-category {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--accent-blue);
    letter-spacing: 0.08em;
  }

  .opinion-item h4 {
    font-size: 1.1rem;
    line-height: 1.25;
    margin: 4px 0 8px 0;
    word-break: keep-all;
  }

  .opinion-item p {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    text-align: justify;
  }

  .opinion-meta {
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .meta-dot {
    width: 3px;
    height: 3px;
    background-color: var(--text-muted);
    border-radius: 50%;
  }

  .opinion-divider {
    border: none;
    border-top: 1px dotted var(--border-light);
    margin-top: 16px;
  }

  .no-other-posts {
    padding: 16px;
    border: 1px dashed var(--border-light);
    background-color: var(--bg-secondary);
  }

  .empty-opinion-text {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin-bottom: 12px;
  }

  .opinion-suggestion {
    border-top: 1px solid var(--border-light);
    padding-top: 8px;
  }

  .suggestion-tag {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--accent-color);
  }

  .opinion-suggestion p {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--text-muted);
  }

  /* Editorial Board section */
  .editorial-board {
    padding-top: 24px;
    padding-bottom: 24px;
  }

  .board-header {
    border-bottom: 2px solid var(--border-color);
    padding-bottom: 4px;
    margin-bottom: 16px;
  }

  .board-header h3 {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .board-content {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 40px;
  }

  .board-statement p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.65;
    text-align: justify;
  }

  .board-members {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .member h5 {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    margin-bottom: 4px;
  }

  .member p {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.3;
  }

  /* Responsive Design */
  @media (max-width: 992px) {
    .broadsheet-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .col {
      padding: 24px 0;
      border-right: none;
    }
    .col-left, .col-center {
      border-bottom: 1px solid var(--border-light);
    }
    .col-left, .col-center, .col-right {
      padding-left: 0;
      padding-right: 0;
    }
    .board-content {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  @media (max-width: 576px) {
    .board-members {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
